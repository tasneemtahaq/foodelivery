// This tells Prisma we are using SQLite (simple file-based database)
// Perfect for beginners — no server needed!
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ── CATEGORY ──────────────────────────────────────────────
// Example: "Burgers", "Pizza", "Drinks"
model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  image     String?  // optional image for the category
  createdAt DateTime @default(now())

  // One category has MANY foods
  foods     Food[]
}

// ── FOOD ──────────────────────────────────────────────────
// Every food item on the menu
model Food {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  price       Float
  image       String?
  isAvailable Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  offerPrice  Float?   // discounted price (optional)
  createdAt   DateTime @default(now())

  // Every food BELONGS TO one category
  categoryId  Int
  category    Category   @relation(fields: [categoryId], references: [id])

  // One food can appear in MANY order items
  orderItems  OrderItem[]
}

// ── CUSTOMER ──────────────────────────────────────────────
// People who place orders
model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  email     String?
  address   String
  city      String
  area      String?
  createdAt DateTime @default(now())

  // One customer can have MANY orders
  orders    Order[]
}

// ── ORDER ─────────────────────────────────────────────────
// A single order placed by a customer
model Order {
  id               Int         @id @default(autoincrement())
  orderNumber      String      @unique // e.g. "ORD-001"
  status           String      @default("pending")
  // Status options: pending, preparing, out_for_delivery, delivered, cancelled

  paymentMethod    String      // cash, bank, jazzcash, easypaisa
  deliveryCharge   Float       @default(50)
  tax              Float       @default(0)
  totalAmount      Float
  instructions     String?     // special delivery instructions
  estimatedTime    String?     // e.g. "30-45 minutes"
  createdAt        DateTime    @default(now())

  // Every order BELONGS TO one customer
  customerId       Int
  customer         Customer    @relation(fields: [customerId], references: [id])

  // One order has MANY order items
  orderItems       OrderItem[]
}

// ── ORDER ITEM ────────────────────────────────────────────
// Each food inside an order
// Example: 2x Burger, 1x Pizza in the same order
model OrderItem {
  id       Int   @id @default(autoincrement())
  quantity Int
  price    Float // price at time of ordering (in case food price changes later)

  // BELONGS TO one order
  orderId  Int
  order    Order  @relation(fields: [orderId], references: [id])

  // BELONGS TO one food
  foodId   Int
  food     Food   @relation(fields: [foodId], references: [id])
}

// ── SETTINGS ──────────────────────────────────────────────
// Restaurant settings — only one row in this table
model Settings {
  id              Int     @id @default(autoincrement())
  restaurantName  String  @default("My Restaurant")
  logo            String?
  deliveryCharge  Float   @default(50)
  openingHours    String  @default("10:00 AM - 11:00 PM")
  address         String  @default("")
  phone           String  @default("")
  taxPercent      Float   @default(0)
}

// ── ADMIN ─────────────────────────────────────────────────
// Simple admin login (email + password only)
model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String   // will be stored as a hashed password (bcrypt)
  createdAt DateTime @default(now())
}